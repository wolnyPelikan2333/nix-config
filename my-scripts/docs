#!/usr/bin/env bash
set -euo pipefail

if [ ! -d /etc/nixos/docs ]; then
  echo "❌ Katalog /etc/nixos/docs nie istnieje."
  exit 1
fi

file=$(cd /etc/nixos/docs && find . -type f | sed 's|^\./||' | fzf --prompt="docs> " --preview 'bat --style=numbers --color=always {} 2>/dev/null || sed -n "1,200p" {}')

if [[ -n "$file" ]]; then
  nvim "/etc/nixos/docs/$file"
fi